{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimal permissions for the Kenzie DeskClerk shell",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/cloudflared", "sidecar": true, "args": true }]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [{ "name": "binaries/cloudflared", "sidecar": true }]
    }
  ]
}
